{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5433;Database=IeltsAuth;Username=admin;Password=<YOUR_POSTGRES_PASSWORD>"
  },
  "Jwt": {
    "Key": "<REPLACE_WITH_LONG_RANDOM_SECRET_MIN_32_CHARS_SAME_FOR_ALL_SERVICES>",
    "Issuer": "IeltsPkm.Auth",
    "Audience": "IeltsPkm.Clients",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30
  }
}
