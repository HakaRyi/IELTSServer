{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth": {
        "ClusterId": "auth",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "lexical": {
        "ClusterId": "knowledgebase",
        "Match": { "Path": "/api/lexical/{**catch-all}" }
      },
      "passages": {
        "ClusterId": "practice",
        "Match": { "Path": "/api/passages/{**catch-all}" }
      },
      "speaking": {
        "ClusterId": "practice",
        "Match": { "Path": "/api/speaking/{**catch-all}" }
      },
      "essays": {
        "ClusterId": "practice",
        "Match": { "Path": "/api/essays/{**catch-all}" }
      },
      "review": {
        "ClusterId": "review",
        "Match": { "Path": "/api/review/{**catch-all}" }
      }
    },
    "Clusters": {
      "auth": {
        "Destinations": { "d1": { "Address": "http://localhost:5072" } }
      },
      "knowledgebase": {
        "Destinations": { "d1": { "Address": "http://localhost:5101" } }
      },
      "practice": {
        "Destinations": { "d1": { "Address": "http://localhost:5069" } }
      },
      "review": {
        "Destinations": { "d1": { "Address": "http://localhost:5070" } }
      }
    }
  }
}
