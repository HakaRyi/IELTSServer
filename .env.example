# Sao chép file này thành .env rồi điền giá trị thật. KHÔNG commit .env.
#
#   cp .env.example .env

# MongoDB (dùng mật khẩu chỉ chữ-số để khỏi phải URL-encode)
MONGO_USER=admin
MONGO_PASSWORD=ChangeMeMongo123

# PostgreSQL (Auth)
POSTGRES_USER=admin
POSTGRES_PASSWORD=ChangeMePostgres123

# JWT — chuỗi ngẫu nhiên >= 32 ký tự, GIỐNG NHAU cho mọi service
JWT_KEY=ChangeMe-please-use-a-long-random-secret-min-32-bytes

# Groq API key (https://console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
